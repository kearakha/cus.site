# =====================================================
# DATABASE — Pilih salah satu: LOCAL | SUPABASE | NEON
# =====================================================

# --- LOCAL (default development) ---
# Postgres.app atau Homebrew postgresql
# DATABASE_URL dan DIRECT_URL boleh sama untuk local (pakai 1 db aja)
DATABASE_URL="postgresql://cus_user:cus_pass@localhost:5432/cus"
DIRECT_URL="postgresql://cus_user:cus_pass@localhost:5432/cus"

# --- SUPABASE (production-ready) ---
# Ambil dari: Supabase Dashboard → Project Settings → Database → Connection string → URI
# DATABASE_URL    → Transaction pooler (port 6543) untuk runtime app di Vercel
# DIRECT_URL      → Direct connection (port 5432) untuk Prisma migrate
# Format:
#   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:[PORT]/postgres
# Contoh:
# DATABASE_URL="postgresql://postgres.abcdefghij:MyP4ss%21@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"
# DIRECT_URL="postgresql://postgres.abcdefghij:MyP4ss%21@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# --- NEON (alternatif serverless) ---
# DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST].neon.tech/cus?sslmode=require"


# =====================================================
# AI — Required untuk generate konten
# Bisa pakai OpenAI langsung, atau aggregator lain via TokenRouter.
# =====================================================

# --- OpenAI langsung (default) ---
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-2024-08-06"

# --- TokenRouter (atau aggregator OpenAI-compatible lain) ---
OPENAI_API_KEY="tr-..."
OPENAI_BASE_URL="https://api.tokenrouter.ai/v1"
OPENAI_MODEL="MiniMax-M3"

# Kalau model kamu support Structured Outputs (response_format json_schema),
# akan dipakai otomatis. Kalau tidak, fallback ke JSON-prompt + manual parse.
# Cek dokumentasi model kamu di TokenRouter untuk fitur Structured Outputs.


# =====================================================
# DOMAIN
# =====================================================
# Domain utama (production). Untuk local dev biarkan default.
NEXT_PUBLIC_ROOT_DOMAIN="cus.site"

# --- Wildcard Subdomain (Vercel production) ---
# Set di Vercel Dashboard → Domains:
#   *.cus.site  → CNAME ke cname.vercel-dns.com
#   cus.site    → primary domain


# =====================================================
# EMAIL — Magic link login & welcome email
# =====================================================
# Pakai Resend (paling simpel, free tier 100/hari). Daftar: https://resend.com
# Kalau kosong di development, magic link bakal ke-log ke terminal
# (lihat console.log) supaya lo bisa test tanpa setup email.

# --- Production: Resend ---
# RESEND_API_KEY="re_xxx"
# RESEND_FROM_EMAIL="Cus.site <noreply@cus.site>"

# --- Alternatif: Postmark / SES ---
# Kontrak di src/lib/email.ts stabil. Tinggal swap implementasi.


# =====================================================
# MISC
# =====================================================
# Token random untuk signing cookie floating admin bar.
# Generate: openssl rand -base64 32
ADMIN_SECRET_PEPPER="change-me-to-random-32-char-string"

# Signing key untuk cus_session cookie (HMAC-SHA256).
# WAJIB di production — tanpa ini cookie tidak aman.
# Generate: openssl rand -base64 32
SESSION_SECRET="change-me-to-random-32-char-string"
